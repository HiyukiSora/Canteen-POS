{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build && composer install --no-dev --optimize-autoloader",
    "watchPatterns": [
      "public/**/*",
      "src/**/*",
      "db/**/*",
      "composer.json",
      "composer.lock"
    ]
  },
  "deploy": {
    "startCommand": "php -S 0.0.0.0:$PORT -t public",
    "healthcheckPath": "/index.php",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
